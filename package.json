{
  "name": "rosetta-cards-mcp",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "start": "node --enable-source-maps dist/server.js",
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml,css,md}\"",
    "tui": "node --loader ts-node/esm src/tui/app.ts",
    "tui:start": "node --enable-source-maps dist/tui/app.js",
    "test": "node --loader ts-node/esm --test tests/*.test.ts",
    "seed": "node --loader ts-node/esm scripts/seed.ts",
    "demo": "bash examples/run_demo.sh",
    "ingest:demo": "node --loader ts-node/esm scripts/ingest_demo.ts",
    "corpus": "node --loader ts-node/esm src/cli/corpus.ts",
    "corpus:local": "node --loader ts-node/esm src/cli/corpus.ts local",
    "corpus:github": "node --loader ts-node/esm src/cli/corpus.ts github",
    "corpus:arxiv": "node --loader ts-node/esm src/cli/corpus.ts arxiv",
    "corpus:synthetic": "node --loader ts-node/esm src/cli/corpus.ts synthetic",
    "visualize": "node --loader ts-node/esm scripts/visualize_chunking.ts",
    "visualize:render": "node --loader ts-node/esm scripts/render_visualization.ts",
    "smoke": "node scripts/smoke.mjs",
    "smoke:render": "SMOKE_RENDER=1 node scripts/smoke.mjs",
    "genesis": "node --loader ts-node/esm scripts/genesis_prove.ts",
    "report": "npx tsx scripts/make_phase_transition_report.mjs",
    "battery": "npx tsx scripts/corpus_battery.mjs --standard",
    "battery:tiny": "npx tsx scripts/corpus_battery.mjs --tiny"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/lib-storage": "^3.1000.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "mammoth": "^1.11.0",
    "neo-blessed": "^0.2.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.47.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "prettier": "^2.8.8",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.5.4"
  }
}
